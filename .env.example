# ================================================================
# IVDR Document Management System — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ================================================================

# ---- JWT ----
JWT_SECRET=change-me-to-a-random-256-bit-string-at-least-64-chars-long-here
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ivdr_db
DB_USERNAME=ivdr_user
DB_PASSWORD=ivdr_secret

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=ivdr_redis_secret

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---- Storage (MinIO local / AWS S3 production) ----
AWS_S3_BUCKET=ivdr-documents
AWS_ACCESS_KEY_ID=ivdr_minio_user
AWS_SECRET_ACCESS_KEY=ivdr_minio_secret
AWS_REGION=ap-southeast-1
# Leave empty to use real AWS; set to http://localhost:9000 for MinIO
AWS_S3_ENDPOINT=http://localhost:9000

# ---- AI ----
# Provider: anthropic | openai
AI_PROVIDER=anthropic
AI_API_KEY=your-api-key-here

# ---- MinIO Console (local only) ----
MINIO_ROOT_USER=ivdr_minio_user
MINIO_ROOT_PASSWORD=ivdr_minio_secret
