# ================================================================
# .gitignore for IVDR Spring Boot Project
# ================================================================

# ---- Environment & Secrets ----
.env
*.env.local
*.pem
*.key

# ---- Maven ----
target/
*.jar
*.war
*.ear

# ---- IDE ----
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
.classpath
.project
.settings/

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Spring Boot ----
application-local.yml
application-prod.yml

# ---- Docker ----
docker-compose.override.yml

# ---- Logs ----
*.log
logs/

# ---- Test outputs ----
surefire-reports/
failsafe-reports/
